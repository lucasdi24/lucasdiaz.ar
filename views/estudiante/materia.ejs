<%- include('../partials/head', { title: materia.nombre, description: materia.descripcion }) %>
<%- include('../partials/nav', { currentPath: '/estudiante' }) %>

<main class="page">
  <header class="estudiante-header">
    <p class="section-label"><a href="/estudiante" style="color:inherit">Apuntes</a> / <%= materia.nombre %></p>
    <h1><%= materia.nombre %></h1>
    <p><%= materia.descripcion %></p>
  </header>

  <div class="materia-full-card">
    <div class="materia-full-header">
      <div class="materia-full-header-left">
        <div class="materia-icon" style="background: <%= materia.color %>18;">
          <span style="color: <%= materia.color %>">✦</span>
        </div>
        <div class="materia-title-group">
          <h2><%= materia.nombre %></h2>
          <div class="materia-badges">
            <span class="badge"><%= materia.año %></span>
            <span class="badge"><%= materia.carrera %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="recursos-list">
      <% materia.recursos.forEach(r => { %>
        <% if (r.tipo === 'video') { %>
        <div class="recurso-video">
          <div class="recurso-video-header">
            <span class="recurso-tipo-chip">video</span>
            <span class="recurso-titulo"><%= r.titulo %></span>
          </div>
          <div class="video-wrapper">
            <iframe src="<%= r.embed %>" title="<%= r.titulo %>" frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <% } else { %>
        <a href="<%= r.url %>" class="recurso-item" target="_blank">
          <div class="recurso-item-left">
            <span class="recurso-tipo-chip"><%= r.tipo %></span>
            <div>
              <div class="recurso-titulo"><%= r.titulo %></div>
              <% if (r.descripcion) { %><div class="recurso-desc"><%= r.descripcion %></div><% } %>
            </div>
          </div>
          <span class="recurso-arrow">→</span>
        </a>
        <% } %>
      <% }) %>
    </div>

    <div class="materia-footer">
      Actualizado el <%= materia.actualizacion %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
